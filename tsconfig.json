{
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/db",
    "src/bin"
  ],
  "compilerOptions": {
    "typeRoots": [
      "./node_modules/@types",
      "./typings"
    ],
    "moduleResolution": "node",
    "target": "es2020",
    "module": "commonjs",
    "outDir": "dist",
    "lib": [
      "es2020"
    ],
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "removeComments": true,
    "newLine": "lf",
    "noEmitOnError": false,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  }
}
