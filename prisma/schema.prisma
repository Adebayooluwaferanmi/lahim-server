// Prisma schema for LaHIM PostgreSQL database
// This is the primary database for complex queries and analytics
// CouchDB remains for offline sync

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Critical Values - Post-analytical stage
model CriticalValue {
  id                 String    @id @default(uuid())
  resultId           String
  patientId          String
  testCodeLoinc      String
  testName           String?
  value              Float
  unitUcum           String?
  referenceRangeLow  Float?
  referenceRangeHigh Float?
  status             String    @default("pending") // pending, acknowledged, resolved
  detectedOn         DateTime  @default(now())
  acknowledgedBy     String?
  acknowledgedOn     DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  result  LabResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  patient Patient   @relation(fields: [patientId], references: [patientId], onDelete: Cascade)

  @@index([resultId])
  @@index([patientId])
  @@index([status])
  @@index([detectedOn])
}

// Patients - Core entity
model Patient {
  id          String    @id @default(uuid())
  patientId   String    @unique // External patient ID (e.g., P00001)
  firstName   String?
  lastName    String?
  dateOfBirth DateTime?
  sex         String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  labOrders               LabOrder[]
  criticalValues           CriticalValue[]
  externalAccessRequests   ExternalAccessRequest[]
  externalAccessTokens     ExternalAccessToken[]

  @@index([patientId])
  @@index([lastName, firstName])
}

// Practitioners - Healthcare providers
model Practitioner {
  id             String   @id @default(uuid())
  practitionerId String   @unique // External practitioner ID
  firstName      String?
  lastName       String?
  title          String? // Dr., Nurse, etc.
  department     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  labOrders     LabOrder[]
  labResults    LabResult[]
  qcResults     QcResult[]
  worklistItems WorklistItem[]

  @@index([practitionerId])
  @@index([lastName, firstName])
}

// Lab Orders - Pre-analytical stage
model LabOrder {
  id             String    @id @default(uuid())
  patientId      String
  testCodeLoinc  String?   // For individual tests (nullable if panel)
  panelId        String?   // For panel orders (nullable if individual test)
  isPanel        Boolean   @default(false) // True if this is a panel order
  status         String // requested, approved, collected, received, in-progress, completed
  priority       String? // stat, urgent, routine, scheduled
  orderedAt      DateTime  @default(now())
  collectedAt    DateTime?
  receivedAt     DateTime?
  finalizedAt    DateTime?
  facilityId     String?
  practitionerId String?
  source         String?   // e.g. external_one_time for one-time external access
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  specimens     LabSpecimen[]
  results       LabResult[]
  worklistItems WorklistItem[]
  transports    SpecimenTransport[]
  testCatalog   TestCatalog?  @relation(fields: [testCodeLoinc], references: [code], onDelete: Restrict)
  panel         TestPanel?     @relation(fields: [panelId], references: [id], onDelete: SetNull)
  patient       Patient        @relation(fields: [patientId], references: [patientId], onDelete: Restrict)
  practitioner  Practitioner?  @relation(fields: [practitionerId], references: [practitionerId], onDelete: SetNull)

  @@index([patientId])
  @@index([status])
  @@index([orderedAt])
  @@index([testCodeLoinc])
  @@index([panelId])
  @@index([practitionerId])
}

// Lab Specimens - Pre-analytical stage
model LabSpecimen {
  id               String   @id @default(uuid())
  orderId          String
  specimenTypeCode String
  collectedAt      DateTime
  container        String?
  accessionNo      String   @unique
  storageLocation  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  order      LabOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  results    LabResult[]
  transports SpecimenTransport[]

  @@index([orderId])
  @@index([accessionNo])
  @@index([collectedAt])
}

// Lab Results - Analytical stage
model LabResult {
  id               String    @id @default(uuid())
  orderId          String
  specimenId       String?
  analyteCodeLoinc String
  resultType       String // numeric, categorical, microbiology, text, image
  valueNumber      Float?
  unitUcum         String?
  valueCode        String?
  valueText        String?
  codeSystem       String?
  refRangeLow      Float?
  refRangeHigh     Float?
  flags            String[] // critical, abnormal, delta-check-failed
  finalizedAt      DateTime?
  performerId      String?
  source           String?   // e.g. external_one_time for one-time external access
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  order            LabOrder                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  specimen         LabSpecimen?             @relation(fields: [specimenId], references: [id], onDelete: SetNull)
  testCatalog      TestCatalog              @relation(fields: [analyteCodeLoinc], references: [code], onDelete: Restrict)
  performer        Practitioner?            @relation(fields: [performerId], references: [practitionerId], onDelete: SetNull)
  microOrganisms   LabMicroOrganism[]
  susceptibilities LabMicroSusceptibility[]
  criticalValues   CriticalValue[]

  @@index([orderId])
  @@index([specimenId])
  @@index([analyteCodeLoinc])
  @@index([finalizedAt])
  @@index([resultType])
  @@index([performerId])
}

// Microbiology Organisms - Analytical stage
model LabMicroOrganism {
  id                 String   @id @default(uuid())
  resultId           String
  organismCodeSnomed String
  organismDisplay    String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  result           LabResult                @relation(fields: [resultId], references: [id], onDelete: Cascade)
  susceptibilities LabMicroSusceptibility[]

  @@index([resultId])
  @@index([organismCodeSnomed])
}

// Microbiology Susceptibilities - Analytical stage
model LabMicroSusceptibility {
  id                   String   @id @default(uuid())
  organismId           String
  resultId             String
  antibioticCode       String // RxNorm/ATC
  antibioticDisplay    String
  method               String? // MIC, Disk diffusion
  micValueNumber       Float?
  micUnitUcum          String?
  interpretationCode   String // S, I, R
  interpretationSystem String? // EUCAST, CLSI
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  organism LabMicroOrganism @relation(fields: [organismId], references: [id], onDelete: Cascade)
  result   LabResult        @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@index([organismId])
  @@index([resultId])
  @@index([antibioticCode])
  @@index([interpretationCode])
}

// Vocabulary Cache - Cached from Vocabulary Service
model VocabularyCache {
  id            String    @id @default(uuid())
  listId        String
  itemCode      String
  itemDisplay   String
  codeSystem    String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  status        String    @default("active")
  locale        String?   @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([listId, itemCode])
  @@index([listId])
  @@index([itemCode])
  @@index([status])
}

// Instruments - Laboratory equipment
model Instrument {
  id           String   @id @default(uuid())
  name         String
  type         String // analyzer, centrifuge, etc.
  manufacturer String?
  model        String?
  serialNumber String?  @unique
  status       String   @default("offline") // online, offline, maintenance
  section      String? // Hematology, Chemistry, Microbiology, etc.
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  qcResults QcResult[]
  worklists Worklist[]

  @@index([status])
  @@index([section])
  @@index([name])
}

// Test Catalog - Laboratory test definitions
model TestCatalog {
  id         String   @id @default(uuid())
  code       String   @unique // LOINC code
  name       String
  department String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  qcResults           QcResult[]
  labOrders           LabOrder[]
  labResults          LabResult[]
  worklistItems       WorklistItem[]
  panelParameters     TestPanelParameter[]

  @@index([code])
  @@index([active])
  @@index([department])
}

// Test Panel - Groups of related tests (e.g., LFT, FBC)
model TestPanel {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., "LFT", "FBC", "LIPID"
  name        String   // e.g., "Liver Function Test"
  description String?
  department  String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parameters  TestPanelParameter[]
  labOrders   LabOrder[]

  @@index([code])
  @@index([active])
  @@index([department])
}

// Panel Parameters - Individual tests within a panel
model TestPanelParameter {
  id            String    @id @default(uuid())
  panelId       String
  parameterCode String    // LOINC code for the parameter
  parameterName String    // Display name (e.g., "AST", "PCV")
  sequence      Int       // Order in panel display
  unit          String?   // UCUM unit code
  refRangeLow   Float?
  refRangeHigh  Float?
  criticalLow   Float?
  criticalHigh  Float?
  defaultValue  String?
  required      Boolean   @default(true) // Must be performed
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  panel         TestPanel   @relation(fields: [panelId], references: [id], onDelete: Cascade)
  testCatalog   TestCatalog @relation(fields: [parameterCode], references: [code], onDelete: Restrict)

  @@unique([panelId, parameterCode]) // One parameter per panel
  @@index([panelId])
  @@index([parameterCode])
}

// Quality Control Results
model QcResult {
  id                  String   @id @default(uuid())
  instrumentId        String?
  testCodeLoinc       String
  qcMaterialLot       String
  targetValue         Float?
  acceptableRangeLow  Float?
  acceptableRangeHigh Float?
  actualValue         Float
  unitUcum            String?
  qcRuleViolations    String[] // 1-2s, 1-3s, 2-2s, R-4s, 4-1s, 10x
  status              String // pass, fail, warning
  runAt               DateTime @default(now())
  performerId         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  instrument  Instrument?   @relation(fields: [instrumentId], references: [id], onDelete: SetNull)
  testCatalog TestCatalog   @relation(fields: [testCodeLoinc], references: [code], onDelete: Restrict)
  performer   Practitioner? @relation(fields: [performerId], references: [practitionerId], onDelete: SetNull)

  @@index([instrumentId])
  @@index([testCodeLoinc])
  @@index([runAt])
  @@index([status])
  @@index([performerId])
}

// Worklists - Analytical stage
model Worklist {
  id           String    @id @default(uuid())
  section      String // Hematology, Chemistry, Microbiology, etc.
  instrumentId String?
  priority     String? // stat, urgent, routine
  status       String    @default("pending") // pending, in-progress, completed
  generatedAt  DateTime  @default(now())
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  items      WorklistItem[]
  instrument Instrument?    @relation(fields: [instrumentId], references: [id], onDelete: SetNull)

  @@index([section])
  @@index([status])
  @@index([generatedAt])
  @@index([instrumentId])
}

model WorklistItem {
  id            String   @id @default(uuid())
  worklistId    String
  orderId       String
  testCodeLoinc String
  assignedTo    String?
  status        String   @default("pending") // pending, in-progress, completed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  worklist             Worklist      @relation(fields: [worklistId], references: [id], onDelete: Cascade)
  order                LabOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  testCatalog          TestCatalog   @relation(fields: [testCodeLoinc], references: [code], onDelete: Restrict)
  assignedPractitioner Practitioner? @relation(fields: [assignedTo], references: [practitionerId], onDelete: SetNull)

  @@index([worklistId])
  @@index([orderId])
  @@index([testCodeLoinc])
  @@index([status])
  @@index([assignedTo])
}

// Specimen Transport - Logistics management
model SpecimenTransport {
  id             String    @id @default(uuid())
  specimenId     String
  orderId        String
  transportType  String // internal, external, courier
  origin         String
  destination    String
  carrier        String?
  trackingNumber String?
  status         String    @default("scheduled") // scheduled, in-transit, delivered, failed, cancelled
  temperature    Float? // For temperature-sensitive specimens
  scheduledAt    DateTime
  pickedUpAt     DateTime?
  deliveredAt    DateTime?
  cost           Float?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  specimen LabSpecimen @relation(fields: [specimenId], references: [id], onDelete: Cascade)
  order    LabOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([specimenId])
  @@index([orderId])
  @@index([status])
  @@index([scheduledAt])
  @@index([transportType])
}

// Equipment - Logistics management
model Equipment {
  id              String    @id @default(uuid())
  name            String
  type            String // analyzer, centrifuge, microscope, refrigerator, freezer, etc.
  manufacturer    String?
  model           String?
  serialNumber    String?   @unique
  location        String?
  status          String    @default("active") // active, maintenance, retired, decommissioned
  purchaseDate    DateTime?
  warrantyExpiry  DateTime?
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  maintenanceRecords EquipmentMaintenance[]

  @@index([type])
  @@index([status])
  @@index([location])
  @@index([name])
}

// Equipment Maintenance - Logistics management
model EquipmentMaintenance {
  id          String    @id @default(uuid())
  equipmentId String
  type        String // preventive, corrective, calibration, repair
  scheduledAt DateTime
  performedAt DateTime?
  performedBy String?
  cost        Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([scheduledAt])
  @@index([type])
}

// Document Control - ISO 15189 Quality Management
model Document {
  id              String    @id @default(uuid())
  documentNumber  String    @unique // Auto-generated (e.g., DOC-2024-001)
  type            String // SOP, Policy, Procedure, Form, Manual
  category        String? // Quality, Technical, Administrative
  title           String
  description     String?
  version         String    @default("1.0")
  status          String    @default("draft") // draft, under-review, approved, active, superseded, archived
  filename        String?
  filePath        String? // Path to stored file
  contentType     String?
  fileSize        Int? // Size in bytes
  effectiveDate   DateTime?
  reviewDate      DateTime?
  nextReviewDate  DateTime?
  approvedBy      String?
  approvedOn      DateTime?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  revisions DocumentRevision[]
  approvals DocumentApproval[]

  @@index([documentNumber])
  @@index([type])
  @@index([status])
  @@index([category])
  @@index([effectiveDate])
}

model DocumentRevision {
  id          String   @id @default(uuid())
  documentId String
  version     String
  changeLog   String?
  revisedBy   String
  revisedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([version])
}

model DocumentApproval {
  id          String   @id @default(uuid())
  documentId String
  approverId  String
  approverName String?
  status      String // pending, approved, rejected
  comments    String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([approverId])
  @@index([status])
}

// Audit Management - ISO 15189 Quality Management
model Audit {
  id              String    @id @default(uuid())
  auditNumber     String    @unique // Auto-generated (e.g., AUD-2024-001)
  type            String // internal, external, supplier
  scope           String
  status          String    @default("planned") // planned, in-progress, completed, cancelled
  scheduledDate   DateTime
  conductedDate   DateTime?
  conductedBy     String?
  auditorName     String?
  department      String?
  findings        String? // JSON or text
  conclusion      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  findingsList AuditFinding[]
  actions      CorrectiveAction[]

  @@index([auditNumber])
  @@index([type])
  @@index([status])
  @@index([scheduledDate])
  @@index([department])
}

model AuditFinding {
  id          String   @id @default(uuid())
  auditId     String
  severity    String // minor, major, critical
  description String
  clause      String? // ISO 15189 clause reference
  status      String   @default("open") // open, in-progress, resolved, closed
  assignedTo  String?
  dueDate     DateTime?
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  audit         Audit             @relation(fields: [auditId], references: [id], onDelete: Cascade)
  correctiveActions CorrectiveAction[]

  @@index([auditId])
  @@index([severity])
  @@index([status])
  @@index([assignedTo])
}

model CorrectiveAction {
  id          String   @id @default(uuid())
  auditId     String?
  findingId   String?
  type         String // corrective, preventive (CAPA)
  description  String
  rootCause    String?
  actionPlan   String
  assignedTo   String?
  dueDate      DateTime
  status       String   @default("open") // open, in-progress, completed, verified, closed
  completedAt  DateTime?
  verifiedBy   String?
  verifiedAt   DateTime?
  effectiveness String? // effective, ineffective, pending
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  audit   Audit?        @relation(fields: [auditId], references: [id], onDelete: SetNull)
  finding AuditFinding? @relation(fields: [findingId], references: [id], onDelete: SetNull)

  @@index([auditId])
  @@index([findingId])
  @@index([type])
  @@index([status])
  @@index([assignedTo])
  @@index([dueDate])
}

// One-time external access (patient-initiated 24h link for doctor/lab)
model ExternalAccessRequest {
  id            String    @id @default(uuid())
  patientId     String    // Core patient ID (Patient.patientId)
  requestedBy   String?   // Portal user id or identifier
  recipientEmail String
  type          String    // VIEW_RECORD | UPDATE_LABS
  status        String    @default("pending") // pending, approved, rejected
  approvedAt    DateTime?
  approvedBy    String?
  tokenId       String?   // Set when approved -> ExternalAccessToken.id
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient Patient             @relation(fields: [patientId], references: [patientId], onDelete: Cascade)
  token   ExternalAccessToken?

  @@index([patientId])
  @@index([status])
  @@index([recipientEmail])
  @@index([createdAt])
}

model ExternalAccessToken {
  id             String    @id @default(uuid())
  requestId      String    @unique
  tokenHash      String    // Hashed token (never store raw)
  patientId      String
  type           String    // VIEW_RECORD | UPDATE_LABS
  expiresAt      DateTime
  maxUses        Int       @default(1)
  useCount       Int       @default(0)
  recipientEmail String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  request ExternalAccessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  patient Patient                @relation(fields: [patientId], references: [patientId], onDelete: Cascade)

  @@index([tokenHash])
  @@index([patientId])
  @@index([expiresAt])
}

// External doctor note (one-time access flow)
model ExternalAccessNote {
  id        String   @id @default(uuid())
  tokenId   String   // ExternalAccessToken.id
  patientId String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tokenId])
  @@index([patientId])
}
